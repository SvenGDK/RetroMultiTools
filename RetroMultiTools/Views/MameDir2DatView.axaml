<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:RetroMultiTools.Localization"
             x:Class="RetroMultiTools.Views.MameDir2DatView">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16" MaxWidth="700" HorizontalAlignment="Left">
        <TextBlock Text="{Binding [MameDir2Dat_Title], Source={x:Static loc:LocalizationManager.Instance}}" FontSize="18" FontWeight="Bold" Foreground="#CDD6F4"/>
        <TextBlock Text="{Binding [MameDir2Dat_Description], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#A6ADC8" TextWrapping="Wrap"/>

        <!-- ROM Directory -->
        <StackPanel Spacing="4">
            <TextBlock Text="{Binding [MameDir2Dat_RomDir], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="RomDirTextBox" IsReadOnly="True"
                         Watermark="{Binding [MameDir2Dat_SelectRomDir], Source={x:Static loc:LocalizationManager.Instance}}" Padding="8,6"/>
                <Button Grid.Column="1" Content="{Binding [Common_Browse], Source={x:Static loc:LocalizationManager.Instance}}" Click="BrowseRomDir_Click"
                        Margin="8,0,0,0" Padding="12,6"/>
            </Grid>
        </StackPanel>

        <!-- DAT Metadata -->
        <StackPanel Spacing="8">
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding [MameDir2Dat_DatName], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
                <TextBox x:Name="DatNameTextBox" Text="Dir2Dat" Padding="8,6"
                         Watermark="{Binding [MameDir2Dat_DefaultName], Source={x:Static loc:LocalizationManager.Instance}}"/>
            </StackPanel>
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding [MameDir2Dat_DatDescription], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
                <TextBox x:Name="DatDescriptionTextBox" Text="{Binding [MameDir2Dat_DefaultDescription], Source={x:Static loc:LocalizationManager.Instance}}" Padding="8,6"/>
            </StackPanel>
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding [MameDir2Dat_DatAuthor], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
                <TextBox x:Name="DatAuthorTextBox" Padding="8,6"/>
            </StackPanel>
        </StackPanel>

        <!-- Options -->
        <StackPanel Spacing="8">
            <CheckBox x:Name="ComputeSha1CheckBox" IsChecked="True" Foreground="#A6ADC8"
                      Content="{Binding [MameDir2Dat_ComputeSHA1], Source={x:Static loc:LocalizationManager.Instance}}"/>
            <CheckBox x:Name="ComputeMd5CheckBox" Foreground="#A6ADC8"
                      Content="{Binding [MameDir2Dat_ComputeMD5], Source={x:Static loc:LocalizationManager.Instance}}"/>
            <CheckBox x:Name="IncludeLooseCheckBox" Foreground="#A6ADC8"
                      Content="{Binding [MameDir2Dat_IncludeLoose], Source={x:Static loc:LocalizationManager.Instance}}"/>
            <CheckBox x:Name="IncludeChdCheckBox" IsChecked="True" Foreground="#A6ADC8"
                      Content="{Binding [MameDir2Dat_IncludeChd], Source={x:Static loc:LocalizationManager.Instance}}"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="ScanButton" Content="{Binding [MameDir2Dat_Scan], Source={x:Static loc:LocalizationManager.Instance}}"
                    Click="ScanButton_Click"
                    Padding="16,10" HorizontalAlignment="Left"
                    IsEnabled="False"/>
            <Button x:Name="ExportButton" Content="{Binding [MameDir2Dat_Export], Source={x:Static loc:LocalizationManager.Instance}}"
                    Click="ExportButton_Click"
                    Padding="16,10" HorizontalAlignment="Left"
                    IsEnabled="False"/>
        </StackPanel>

        <!-- Progress -->
        <StackPanel x:Name="ProgressPanel" IsVisible="False" Spacing="4">
            <ProgressBar IsIndeterminate="True" Height="4" Foreground="#89B4FA"/>
            <TextBlock x:Name="ProgressText" Foreground="#A6ADC8" FontSize="12"/>
        </StackPanel>

        <!-- Status -->
        <Border x:Name="StatusBorder" Background="#181825" CornerRadius="6" Padding="12"
                IsVisible="False">
            <TextBlock x:Name="StatusText" TextWrapping="Wrap" Foreground="#CDD6F4"/>
        </Border>

        <!-- Results List -->
        <Border x:Name="ResultsBorder" Background="#181825" CornerRadius="6" Padding="12"
                IsVisible="False" MaxHeight="350">
            <ScrollViewer>
                <TextBlock x:Name="ResultsText" Foreground="#A6ADC8" FontSize="12"
                           FontFamily="Consolas,Courier New,monospace" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>
    </StackPanel>
    </ScrollViewer>
</UserControl>
