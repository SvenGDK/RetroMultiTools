<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:RetroMultiTools.Localization"
             x:Class="RetroMultiTools.Views.SnesHeaderToolView">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Left">
        <TextBlock Text="{Binding [SnesHeader_Title], Source={x:Static loc:LocalizationManager.Instance}}" FontSize="18" FontWeight="Bold" Foreground="#CDD6F4"/>
        <TextBlock Text="{Binding [SnesHeader_Description], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#A6ADC8" TextWrapping="Wrap"/>

        <!-- Input File -->
        <StackPanel Spacing="4">
            <TextBlock Text="{Binding [SnesHeader_RomFile], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="InputFileTextBox" IsReadOnly="True"
                         Watermark="{Binding [SnesHeader_SelectFile], Source={x:Static loc:LocalizationManager.Instance}}" Padding="8,6"/>
                <Button Grid.Column="1" Content="{Binding [Common_Browse], Source={x:Static loc:LocalizationManager.Instance}}" Click="BrowseInput_Click"
                        Margin="8,0,0,0" Padding="12,6"/>
            </Grid>
        </StackPanel>

        <!-- Header Status -->
        <Border x:Name="HeaderStatusPanel" Background="#181825" CornerRadius="6" Padding="12"
                IsVisible="False">
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding [SnesHeader_HeaderStatus], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8" FontSize="12"/>
                <TextBlock x:Name="HeaderStatusText" FontWeight="Bold" Foreground="#CDD6F4"/>
                <TextBlock x:Name="FileSizeText" Foreground="#A6ADC8" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Output File -->
        <StackPanel Spacing="4">
            <TextBlock Text="{Binding [Common_OutputFile], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="OutputFileTextBox" Watermark="{Binding [SnesHeader_OutputPath], Source={x:Static loc:LocalizationManager.Instance}}" Padding="8,6"/>
                <Button Grid.Column="1" Content="{Binding [Common_Browse], Source={x:Static loc:LocalizationManager.Instance}}" Click="BrowseOutput_Click"
                        Margin="8,0,0,0" Padding="12,6"/>
            </Grid>
        </StackPanel>

        <!-- Action Buttons -->
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="RemoveHeaderButton" Content="{Binding [SnesHeader_RemoveHeader], Source={x:Static loc:LocalizationManager.Instance}}"
                    Click="RemoveHeader_Click"
                    Padding="16,10" IsEnabled="False"/>
            <Button x:Name="AddHeaderButton" Content="{Binding [SnesHeader_AddHeader], Source={x:Static loc:LocalizationManager.Instance}}"
                    Click="AddHeader_Click"
                    Padding="16,10" IsEnabled="False"/>
        </StackPanel>

        <!-- Progress -->
        <StackPanel x:Name="ProgressPanel" IsVisible="False" Spacing="4">
            <ProgressBar IsIndeterminate="True" Height="4" Foreground="#89B4FA"/>
            <TextBlock x:Name="ProgressText" Foreground="#A6ADC8" FontSize="12"/>
        </StackPanel>

        <!-- Status -->
        <Border x:Name="StatusBorder" Background="#181825" CornerRadius="6" Padding="12"
                IsVisible="False">
            <TextBlock x:Name="StatusText" TextWrapping="Wrap" Foreground="#CDD6F4"/>
        </Border>
    </StackPanel>
    </ScrollViewer>
</UserControl>
