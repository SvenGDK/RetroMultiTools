<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:RetroMultiTools.Localization"
             x:Class="RetroMultiTools.Views.RomOrganizerView">
    <DockPanel>
        <!-- Top Controls -->
        <StackPanel DockPanel.Dock="Top" Spacing="16" Margin="0,0,0,12">
            <TextBlock Text="{Binding [Organizer_Title], Source={x:Static loc:LocalizationManager.Instance}}" FontSize="18" FontWeight="Bold" Foreground="#CDD6F4"/>
            <TextBlock Text="{Binding [Organizer_Description], Source={x:Static loc:LocalizationManager.Instance}}"
                       Foreground="#A6ADC8" TextWrapping="Wrap"/>

            <!-- Source Folder -->
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding [Organizer_SourceFolder], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox x:Name="SourcePathTextBox" IsReadOnly="True"
                             Watermark="{Binding [Organizer_SelectSource], Source={x:Static loc:LocalizationManager.Instance}}" Padding="8,6"/>
                    <Button Grid.Column="1" Content="{Binding [Common_Browse], Source={x:Static loc:LocalizationManager.Instance}}" Click="BrowseSource_Click"
                            Margin="8,0,0,0" Padding="12,6"/>
                </Grid>
            </StackPanel>

            <!-- Output Folder -->
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding [Organizer_OutputFolder], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox x:Name="OutputPathTextBox" IsReadOnly="True"
                             Watermark="{Binding [Organizer_SelectOutput], Source={x:Static loc:LocalizationManager.Instance}}" Padding="8,6"/>
                    <Button Grid.Column="1" Content="{Binding [Common_Browse], Source={x:Static loc:LocalizationManager.Instance}}" Click="BrowseOutput_Click"
                            Margin="8,0,0,0" Padding="12,6"/>
                </Grid>
            </StackPanel>

            <!-- System Filter -->
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding [Organizer_SystemFilter], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
                <ComboBox x:Name="SystemFilterComboBox" MinWidth="300" HorizontalAlignment="Left" Padding="8,6"/>
            </StackPanel>

            <!-- Copy / Move Mode -->
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding [Common_Mode], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <RadioButton x:Name="CopyMode" Content="{Binding [Organizer_CopyRoms], Source={x:Static loc:LocalizationManager.Instance}}"
                                 GroupName="RomOrganizerMode" IsChecked="True" Foreground="#CDD6F4"/>
                    <RadioButton x:Name="MoveMode" Content="{Binding [Organizer_MoveRoms], Source={x:Static loc:LocalizationManager.Instance}}"
                                 GroupName="RomOrganizerMode" Foreground="#CDD6F4"/>
                </StackPanel>
            </StackPanel>

            <!-- Action Buttons -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="ScanButton" Content="{Binding [Organizer_Scan], Source={x:Static loc:LocalizationManager.Instance}}"
                        Click="ScanButton_Click"
                        Padding="16,10" HorizontalAlignment="Left"
                        IsEnabled="False"/>
                <Button x:Name="OrganizeButton" Content="{Binding [Organizer_Organize], Source={x:Static loc:LocalizationManager.Instance}}"
                        Click="OrganizeButton_Click"
                        Padding="16,10" HorizontalAlignment="Left"
                        IsVisible="False"/>
            </StackPanel>

            <!-- Progress -->
            <StackPanel x:Name="ProgressPanel" IsVisible="False" Spacing="4">
                <ProgressBar IsIndeterminate="True" Height="4" Foreground="#89B4FA"/>
                <TextBlock x:Name="ProgressText" Foreground="#A6ADC8" FontSize="12"/>
            </StackPanel>

            <!-- Summary -->
            <Border x:Name="StatusBorder" Background="#181825" CornerRadius="6" Padding="12"
                    IsVisible="False">
                <TextBlock x:Name="StatusText" Foreground="#CDD6F4" TextWrapping="Wrap"/>
            </Border>
        </StackPanel>

        <!-- Scanned ROM List -->
        <ScrollViewer>
            <ItemsControl x:Name="RomList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#181825" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding FileName}" Foreground="#CDD6F4"
                                               FontSize="13" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding SystemName}" Foreground="#89B4FA" FontSize="12"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding FileSizeFormatted}" Foreground="#6C7086"
                                           FontSize="12" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
