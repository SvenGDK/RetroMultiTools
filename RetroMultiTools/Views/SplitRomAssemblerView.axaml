<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:RetroMultiTools.Localization"
             x:Class="RetroMultiTools.Views.SplitRomAssemblerView">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Left">
        <TextBlock Text="{Binding [SplitRom_Title], Source={x:Static loc:LocalizationManager.Instance}}" FontSize="18" FontWeight="Bold" Foreground="#CDD6F4"/>
        <TextBlock Text="{Binding [SplitRom_Description], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#A6ADC8" TextWrapping="Wrap"/>

        <!-- Input File (First Part) -->
        <StackPanel Spacing="4">
            <TextBlock Text="{Binding [SplitRom_FirstPart], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="InputFileTextBox" IsReadOnly="True"
                         Watermark="{Binding [SplitRom_SelectFirst], Source={x:Static loc:LocalizationManager.Instance}}" Padding="8,6"/>
                <Button Grid.Column="1" Content="{Binding [Common_Browse], Source={x:Static loc:LocalizationManager.Instance}}" Click="BrowseInput_Click"
                        Margin="8,0,0,0" Padding="12,6"/>
            </Grid>
        </StackPanel>

        <!-- Detected Parts -->
        <Border x:Name="PartsPanel" Background="#181825" CornerRadius="6" Padding="12"
                IsVisible="False">
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding [SplitRom_DetectedParts], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8" FontWeight="SemiBold"/>
                <TextBlock x:Name="PartsText" Foreground="#CDD6F4" FontSize="12"
                           FontFamily="Consolas,Courier New,monospace" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Output File -->
        <StackPanel Spacing="4">
            <TextBlock Text="{Binding [Common_OutputFile], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="OutputFileTextBox" Watermark="{Binding [Common_OutputPath], Source={x:Static loc:LocalizationManager.Instance}}" Padding="8,6"/>
                <Button Grid.Column="1" Content="{Binding [Common_Browse], Source={x:Static loc:LocalizationManager.Instance}}" Click="BrowseOutput_Click"
                        Margin="8,0,0,0" Padding="12,6"/>
            </Grid>
        </StackPanel>

        <!-- Assemble Button -->
        <Button x:Name="AssembleButton" Content="{Binding [SplitRom_Assemble], Source={x:Static loc:LocalizationManager.Instance}}"
                Click="AssembleButton_Click"
                Padding="16,10" HorizontalAlignment="Left"
                IsEnabled="False"/>

        <!-- Progress -->
        <StackPanel x:Name="ProgressPanel" IsVisible="False" Spacing="4">
            <ProgressBar IsIndeterminate="True" Height="4" Foreground="#89B4FA"/>
            <TextBlock x:Name="ProgressText" Foreground="#A6ADC8" FontSize="12"/>
        </StackPanel>

        <!-- Status -->
        <Border x:Name="StatusBorder" Background="#181825" CornerRadius="6" Padding="12"
                IsVisible="False">
            <TextBlock x:Name="StatusText" TextWrapping="Wrap" Foreground="#CDD6F4"/>
        </Border>
    </StackPanel>
    </ScrollViewer>
</UserControl>
