<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:RetroMultiTools.Localization"
             x:Class="RetroMultiTools.Views.SaveFileConverterView">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Left">
        <TextBlock Text="{Binding [SaveConv_Title], Source={x:Static loc:LocalizationManager.Instance}}" FontSize="18" FontWeight="Bold" Foreground="#CDD6F4"/>
        <TextBlock Text="{Binding [SaveConv_Description], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#A6ADC8" TextWrapping="Wrap"/>

        <!-- Input File -->
        <StackPanel Spacing="4">
            <TextBlock Text="{Binding [SaveConv_InputFile], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="InputFileTextBox" IsReadOnly="True"
                         Watermark="{Binding [SaveConv_SelectFile], Source={x:Static loc:LocalizationManager.Instance}}" Padding="8,6"/>
                <Button Grid.Column="1" Content="{Binding [Common_Browse], Source={x:Static loc:LocalizationManager.Instance}}" Click="BrowseInput_Click"
                        Margin="8,0,0,0" Padding="12,6"/>
            </Grid>
        </StackPanel>

        <!-- File Info -->
        <Border x:Name="InfoPanel" Background="#181825" CornerRadius="6" Padding="12"
                IsVisible="False">
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding [SaveConv_FileSize], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8" Margin="0,0,12,6"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="FileSizeText" Foreground="#CDD6F4" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding [SaveConv_DetectedType], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8" Margin="0,0,12,6"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DetectedTypeText" Foreground="#CDD6F4" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding [SaveConv_PowerOfTwo], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8" Margin="0,0,12,0"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="PowerOfTwoText" Foreground="#CDD6F4"/>
            </Grid>
        </Border>

        <!-- Conversion Type -->
        <StackPanel Spacing="4">
            <TextBlock Text="{Binding [SaveConv_Conversion], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <ComboBox x:Name="ConversionComboBox" MinWidth="300" SelectedIndex="0"
                     SelectionChanged="ConversionComboBox_SelectionChanged">
                <ComboBoxItem Content="{Binding [SaveConv_SwapEndian16], Source={x:Static loc:LocalizationManager.Instance}}"/>
                <ComboBoxItem Content="{Binding [SaveConv_SwapEndian32], Source={x:Static loc:LocalizationManager.Instance}}"/>
                <ComboBoxItem Content="{Binding [SaveConv_PadPowerOfTwo], Source={x:Static loc:LocalizationManager.Instance}}"/>
                <ComboBoxItem Content="{Binding [SaveConv_TrimZeros], Source={x:Static loc:LocalizationManager.Instance}}"/>
                <ComboBoxItem Content="{Binding [SaveConv_TrimFF], Source={x:Static loc:LocalizationManager.Instance}}"/>
                <ComboBoxItem Content="{Binding [SaveConv_SrmToSav], Source={x:Static loc:LocalizationManager.Instance}}"/>
                <ComboBoxItem Content="{Binding [SaveConv_SavToSrm], Source={x:Static loc:LocalizationManager.Instance}}"/>
            </ComboBox>
        </StackPanel>

        <!-- Output File -->
        <StackPanel Spacing="4">
            <TextBlock Text="{Binding [Common_OutputFile], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="OutputFileTextBox" Watermark="{Binding [Common_OutputPath], Source={x:Static loc:LocalizationManager.Instance}}" Padding="8,6"/>
                <Button Grid.Column="1" Content="{Binding [Common_Browse], Source={x:Static loc:LocalizationManager.Instance}}" Click="BrowseOutput_Click"
                        Margin="8,0,0,0" Padding="12,6"/>
            </Grid>
        </StackPanel>

        <!-- Convert Button -->
        <Button x:Name="ConvertButton" Content="{Binding [SaveConv_Convert], Source={x:Static loc:LocalizationManager.Instance}}"
                Click="ConvertButton_Click"
                Padding="16,10" HorizontalAlignment="Left"
                IsEnabled="False"/>

        <!-- Progress -->
        <StackPanel x:Name="ProgressPanel" IsVisible="False" Spacing="4">
            <ProgressBar IsIndeterminate="True" Height="4" Foreground="#89B4FA"/>
            <TextBlock x:Name="ProgressText" Foreground="#A6ADC8" FontSize="12"/>
        </StackPanel>

        <!-- Status -->
        <Border x:Name="StatusBorder" Background="#181825" CornerRadius="6" Padding="12"
                IsVisible="False">
            <TextBlock x:Name="StatusText" TextWrapping="Wrap" Foreground="#CDD6F4"/>
        </Border>
    </StackPanel>
    </ScrollViewer>
</UserControl>
