<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:RetroMultiTools.Localization"
             x:Class="RetroMultiTools.Views.RomRenamerView">
    <DockPanel>
        <!-- Top Controls -->
        <StackPanel DockPanel.Dock="Top" Spacing="16" Margin="0,0,0,12">
            <TextBlock Text="{Binding [Renamer_Title], Source={x:Static loc:LocalizationManager.Instance}}" FontSize="18" FontWeight="Bold" Foreground="#CDD6F4"/>
            <TextBlock Text="{Binding [Renamer_Description], Source={x:Static loc:LocalizationManager.Instance}}"
                       Foreground="#A6ADC8" TextWrapping="Wrap"/>

            <!-- Mode Selection -->
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding [Common_Mode], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <RadioButton x:Name="SingleMode" Content="{Binding [Common_SingleRom], Source={x:Static loc:LocalizationManager.Instance}}"
                                 IsChecked="True" Foreground="#CDD6F4"/>
                    <RadioButton x:Name="BatchMode" Content="{Binding [Common_BatchDirectory], Source={x:Static loc:LocalizationManager.Instance}}"
                                 Foreground="#CDD6F4"/>
                </StackPanel>
            </StackPanel>

            <!-- File/Folder Selection -->
            <StackPanel Spacing="4">
                <TextBlock x:Name="InputLabel" Text="{Binding [Common_RomFile], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox x:Name="InputPathTextBox" IsReadOnly="True"
                             Watermark="{Binding [Renamer_SelectFile], Source={x:Static loc:LocalizationManager.Instance}}" Padding="8,6"/>
                    <Button Grid.Column="1" Content="{Binding [Common_Browse], Source={x:Static loc:LocalizationManager.Instance}}" Click="BrowseInput_Click"
                            Margin="8,0,0,0" Padding="12,6"/>
                </Grid>
            </StackPanel>

            <Button x:Name="PreviewButton" Content="{Binding [Renamer_Preview], Source={x:Static loc:LocalizationManager.Instance}}"
                    Click="PreviewButton_Click"
                    Padding="16,10" HorizontalAlignment="Left"
                    IsEnabled="False"/>

            <!-- Progress -->
            <StackPanel x:Name="ProgressPanel" IsVisible="False" Spacing="4">
                <ProgressBar IsIndeterminate="True" Height="4" Foreground="#89B4FA"/>
                <TextBlock x:Name="ProgressText" Foreground="#A6ADC8" FontSize="12"/>
            </StackPanel>

            <!-- Apply Button -->
            <Button x:Name="ApplyButton" Content="{Binding [Renamer_Apply], Source={x:Static loc:LocalizationManager.Instance}}"
                    Click="ApplyButton_Click"
                    Padding="16,10" HorizontalAlignment="Left"
                    IsVisible="False"/>

            <!-- Summary -->
            <Border x:Name="StatusBorder" Background="#181825" CornerRadius="6" Padding="12"
                    IsVisible="False">
                <TextBlock x:Name="StatusText" Foreground="#CDD6F4" TextWrapping="Wrap"/>
            </Border>
        </StackPanel>

        <!-- Preview Results -->
        <ScrollViewer>
            <ItemsControl x:Name="PreviewList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#181825" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding OriginalName}" Foreground="#F9E2AF"
                                           FontSize="13" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Arrow}" Foreground="#A6ADC8" FontSize="12"/>
                                <TextBlock Text="{Binding NewName}" Foreground="#A6E3A1"
                                           FontSize="13" FontWeight="Bold"/>
                                <TextBlock Text="{Binding System}" Foreground="#6C7086" FontSize="11"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
