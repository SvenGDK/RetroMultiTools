<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:RetroMultiTools.Localization"
             x:Class="RetroMultiTools.Views.DuplicateFinderView">
    <DockPanel>
        <!-- Top Controls -->
        <StackPanel DockPanel.Dock="Top" Spacing="16" Margin="0,0,0,12">
            <TextBlock Text="{Binding [Duplicates_Title], Source={x:Static loc:LocalizationManager.Instance}}" FontSize="18" FontWeight="Bold" Foreground="#CDD6F4"/>
            <TextBlock Text="{Binding [Duplicates_Description], Source={x:Static loc:LocalizationManager.Instance}}"
                       Foreground="#A6ADC8" TextWrapping="Wrap"/>

            <!-- Folder Selection -->
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding [Duplicates_RomFolder], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox x:Name="FolderPathTextBox" IsReadOnly="True"
                             Watermark="{Binding [Duplicates_SelectFolder], Source={x:Static loc:LocalizationManager.Instance}}" Padding="8,6"/>
                    <Button Grid.Column="1" Content="{Binding [Common_Browse], Source={x:Static loc:LocalizationManager.Instance}}" Click="BrowseFolder_Click"
                            Margin="8,0,0,0" Padding="12,6"/>
                </Grid>
            </StackPanel>

            <Button x:Name="ScanButton" Content="{Binding [Duplicates_Find], Source={x:Static loc:LocalizationManager.Instance}}"
                    Click="ScanButton_Click"
                    Padding="16,10" HorizontalAlignment="Left"
                    IsEnabled="False"/>

            <!-- Progress -->
            <StackPanel x:Name="ProgressPanel" IsVisible="False" Spacing="4">
                <ProgressBar IsIndeterminate="True" Height="4" Foreground="#89B4FA"/>
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock x:Name="ProgressText" Foreground="#A6ADC8" FontSize="12"/>
                    <Button x:Name="CancelButton" Grid.Column="1"
                            Content="{Binding [Common_Cancel], Source={x:Static loc:LocalizationManager.Instance}}"
                            Click="CancelButton_Click"
                            IsVisible="False" Padding="12,4" Margin="8,0,0,0"/>
                </Grid>
            </StackPanel>

            <!-- Summary -->
            <Border x:Name="SummaryPanel" Background="#181825" CornerRadius="6" Padding="12"
                    IsVisible="False">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="SummaryText" Foreground="#CDD6F4" TextWrapping="Wrap" FontWeight="Bold"/>
                    <StackPanel x:Name="DeletePanel" IsVisible="False" Orientation="Horizontal" Spacing="8">
                        <Button x:Name="DeleteButton"
                                Content="{Binding [Duplicates_DeleteDuplicates], Source={x:Static loc:LocalizationManager.Instance}}"
                                Click="DeleteButton_Click"
                                Padding="12,6" Background="#45475A"/>
                    </StackPanel>
                    <StackPanel x:Name="ConfirmDeletePanel" IsVisible="False" Spacing="8">
                        <TextBlock x:Name="ConfirmDeleteText" Foreground="#F38BA8" TextWrapping="Wrap" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="ConfirmDeleteButton"
                                    Content="{Binding [Duplicates_ConfirmDelete], Source={x:Static loc:LocalizationManager.Instance}}"
                                    Click="ConfirmDelete_Click"
                                    Padding="12,6" Background="#F38BA8" Foreground="#1E1E2E"/>
                            <Button x:Name="CancelDeleteButton"
                                    Content="{Binding [Common_Cancel], Source={x:Static loc:LocalizationManager.Instance}}"
                                    Click="CancelDelete_Click"
                                    Padding="12,6"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Results -->
        <ScrollViewer>
            <ItemsControl x:Name="DuplicateList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#181825" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding Header}" Foreground="#F9E2AF"
                                           FontWeight="Bold" FontSize="13"/>
                                <ItemsControl ItemsSource="{Binding Files}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="#A6ADC8"
                                                       FontSize="12" Margin="12,2,0,0"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
