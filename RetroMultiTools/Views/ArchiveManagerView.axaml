<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:RetroMultiTools.Localization"
             x:Class="RetroMultiTools.Views.ArchiveManagerView">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Left">
        <TextBlock Text="{Binding [Archive_Title], Source={x:Static loc:LocalizationManager.Instance}}" FontSize="18" FontWeight="Bold" Foreground="#CDD6F4"/>
        <TextBlock Text="{Binding [Archive_Description], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#A6ADC8" TextWrapping="Wrap"/>

        <!-- Operation Selection -->
        <StackPanel Spacing="4">
            <TextBlock Text="{Binding [Archive_Operation], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <RadioButton x:Name="ExtractRadio" Content="{Binding [Archive_OpExtract], Source={x:Static loc:LocalizationManager.Instance}}"
                             GroupName="ArchiveOperation"
                             IsChecked="True" Foreground="#CDD6F4"
                             IsCheckedChanged="OperationRadio_Checked"/>
                <RadioButton x:Name="CreateRadio" Content="{Binding [Archive_OpCreate], Source={x:Static loc:LocalizationManager.Instance}}"
                             GroupName="ArchiveOperation"
                             Foreground="#CDD6F4"
                             IsCheckedChanged="OperationRadio_Checked"/>
            </StackPanel>
        </StackPanel>

        <!-- Mode Selection -->
        <StackPanel Spacing="4">
            <TextBlock Text="{Binding [Common_Mode], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <RadioButton x:Name="SingleModeRadio" Content="{Binding [Archive_SingleFile], Source={x:Static loc:LocalizationManager.Instance}}"
                             GroupName="ArchiveMode"
                             IsChecked="True" Foreground="#CDD6F4"
                             IsCheckedChanged="ModeRadio_Checked"/>
                <RadioButton x:Name="BatchModeRadio" Content="{Binding [Common_BatchDirectory], Source={x:Static loc:LocalizationManager.Instance}}"
                             GroupName="ArchiveMode"
                             Foreground="#CDD6F4"
                             IsCheckedChanged="ModeRadio_Checked"/>
            </StackPanel>
        </StackPanel>

        <!-- Create-specific: batch option -->
        <StackPanel x:Name="CreateBatchOptionPanel" Spacing="4" IsVisible="False">
            <CheckBox x:Name="OnePerFileCheckBox" Content="{Binding [Archive_OnePerFile], Source={x:Static loc:LocalizationManager.Instance}}"
                      IsChecked="True" Foreground="#CDD6F4"/>
        </StackPanel>

        <!-- Input Selection -->
        <StackPanel Spacing="4">
            <TextBlock x:Name="InputLabel" Text="{Binding [Archive_ArchiveFile], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="InputPathTextBox" IsReadOnly="True"
                         Watermark="{Binding [Archive_SelectArchive], Source={x:Static loc:LocalizationManager.Instance}}" Padding="8,6"/>
                <Button Grid.Column="1" Content="{Binding [Common_Browse], Source={x:Static loc:LocalizationManager.Instance}}" Click="BrowseInput_Click"
                        Margin="8,0,0,0" Padding="12,6"/>
            </Grid>
        </StackPanel>

        <!-- Output -->
        <StackPanel Spacing="4">
            <TextBlock x:Name="OutputLabel" Text="{Binding [Archive_OutputDir], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="OutputPathTextBox" Watermark="{Binding [Common_OutputPath], Source={x:Static loc:LocalizationManager.Instance}}" Padding="8,6"/>
                <Button Grid.Column="1" Content="{Binding [Common_Browse], Source={x:Static loc:LocalizationManager.Instance}}" Click="BrowseOutput_Click"
                        Margin="8,0,0,0" Padding="12,6"/>
            </Grid>
        </StackPanel>

        <!-- Action Button -->
        <Button x:Name="ActionButton" Content="{Binding [Archive_Extract], Source={x:Static loc:LocalizationManager.Instance}}"
                Click="ActionButton_Click"
                Padding="16,10" HorizontalAlignment="Left"
                IsEnabled="False"/>

        <!-- Progress -->
        <StackPanel x:Name="ProgressPanel" IsVisible="False" Spacing="4">
            <ProgressBar IsIndeterminate="True" Height="4" Foreground="#89B4FA"/>
            <TextBlock x:Name="ProgressText" Foreground="#A6ADC8" FontSize="12"/>
        </StackPanel>

        <!-- Status -->
        <Border x:Name="StatusBorder" Background="#181825" CornerRadius="6" Padding="12"
                IsVisible="False">
            <TextBlock x:Name="StatusText" TextWrapping="Wrap" Foreground="#CDD6F4"/>
        </Border>

        <!-- Results -->
        <Border x:Name="ResultsBorder" Background="#181825" CornerRadius="6" Padding="12"
                IsVisible="False" MaxHeight="300">
            <ScrollViewer>
                <TextBlock x:Name="ResultsText" Foreground="#A6ADC8" FontSize="12"
                           FontFamily="Consolas,Courier New,monospace" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>
    </StackPanel>
    </ScrollViewer>
</UserControl>
