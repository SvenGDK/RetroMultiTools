<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:RetroMultiTools.Localization"
             x:Class="RetroMultiTools.Views.MameSetRebuilderView">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16" MaxWidth="700" HorizontalAlignment="Left">
        <TextBlock Text="{Binding [MameRebuilder_Title], Source={x:Static loc:LocalizationManager.Instance}}" FontSize="18" FontWeight="Bold" Foreground="#CDD6F4"/>
        <TextBlock Text="{Binding [MameRebuilder_Description], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#A6ADC8" TextWrapping="Wrap"/>

        <!-- MAME XML Database -->
        <StackPanel Spacing="4">
            <TextBlock Text="{Binding [MameRebuilder_XmlFile], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="XmlFileTextBox" IsReadOnly="True"
                         Watermark="{Binding [MameRebuilder_SelectXml], Source={x:Static loc:LocalizationManager.Instance}}" Padding="8,6"/>
                <Button Grid.Column="1" Content="{Binding [Common_Browse], Source={x:Static loc:LocalizationManager.Instance}}" Click="BrowseXml_Click"
                        Margin="8,0,0,0" Padding="12,6"/>
            </Grid>
        </StackPanel>

        <!-- XML Info -->
        <Border x:Name="XmlInfoPanel" Background="#181825" CornerRadius="6" Padding="12"
                IsVisible="False">
            <TextBlock x:Name="XmlInfoText" Foreground="#A6ADC8" FontSize="12"/>
        </Border>

        <!-- Source Directory -->
        <StackPanel Spacing="4">
            <TextBlock Text="{Binding [MameRebuilder_SourceDir], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="SourceDirTextBox" IsReadOnly="True"
                         Watermark="{Binding [MameRebuilder_SelectSourceDir], Source={x:Static loc:LocalizationManager.Instance}}" Padding="8,6"/>
                <Button Grid.Column="1" Content="{Binding [Common_Browse], Source={x:Static loc:LocalizationManager.Instance}}" Click="BrowseSourceDir_Click"
                        Margin="8,0,0,0" Padding="12,6"/>
            </Grid>
        </StackPanel>

        <!-- Output Directory -->
        <StackPanel Spacing="4">
            <TextBlock Text="{Binding [MameRebuilder_OutputDir], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="OutputDirTextBox" IsReadOnly="True"
                         Watermark="{Binding [MameRebuilder_SelectOutputDir], Source={x:Static loc:LocalizationManager.Instance}}" Padding="8,6"/>
                <Button Grid.Column="1" Content="{Binding [Common_Browse], Source={x:Static loc:LocalizationManager.Instance}}" Click="BrowseOutputDir_Click"
                        Margin="8,0,0,0" Padding="12,6"/>
            </Grid>
        </StackPanel>

        <!-- Options -->
        <StackPanel Spacing="8">
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding [MameRebuilder_Mode], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
                <ComboBox x:Name="ModeComboBox" SelectedIndex="0" MinWidth="200">
                    <ComboBoxItem Content="{Binding [MameRebuilder_ModeSplit], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    <ComboBoxItem Content="{Binding [MameRebuilder_ModeNonMerged], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    <ComboBoxItem Content="{Binding [MameRebuilder_ModeMerged], Source={x:Static loc:LocalizationManager.Instance}}"/>
                </ComboBox>
            </StackPanel>
            <CheckBox x:Name="OverwriteCheckBox" Foreground="#A6ADC8"
                      Content="{Binding [MameRebuilder_Overwrite], Source={x:Static loc:LocalizationManager.Instance}}"/>
            <CheckBox x:Name="OnlyCompleteCheckBox" Foreground="#A6ADC8"
                      Content="{Binding [MameRebuilder_OnlyComplete], Source={x:Static loc:LocalizationManager.Instance}}"/>
        </StackPanel>

        <!-- Rebuild Button -->
        <Button x:Name="RebuildButton" Content="{Binding [MameRebuilder_Rebuild], Source={x:Static loc:LocalizationManager.Instance}}"
                Click="RebuildButton_Click"
                Padding="16,10" HorizontalAlignment="Left"
                IsEnabled="False"/>

        <!-- Progress -->
        <StackPanel x:Name="ProgressPanel" IsVisible="False" Spacing="4">
            <ProgressBar IsIndeterminate="True" Height="4" Foreground="#89B4FA"/>
            <TextBlock x:Name="ProgressText" Foreground="#A6ADC8" FontSize="12"/>
        </StackPanel>

        <!-- Status -->
        <Border x:Name="StatusBorder" Background="#181825" CornerRadius="6" Padding="12"
                IsVisible="False">
            <TextBlock x:Name="StatusText" TextWrapping="Wrap" Foreground="#CDD6F4"/>
        </Border>

        <!-- Results List -->
        <Border x:Name="ResultsBorder" Background="#181825" CornerRadius="6" Padding="12"
                IsVisible="False" MaxHeight="350">
            <ScrollViewer>
                <TextBlock x:Name="ResultsText" Foreground="#A6ADC8" FontSize="12"
                           FontFamily="Consolas,Courier New,monospace" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>
    </StackPanel>
    </ScrollViewer>
</UserControl>
