<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:RetroMultiTools.Localization"
             x:Class="RetroMultiTools.Views.RetroArch.RetroArchIntegrationView">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Left">
        <TextBlock Text="{Binding [RAIntegration_Title], Source={x:Static loc:LocalizationManager.Instance}}"
                   FontSize="18" FontWeight="Bold" Foreground="#CDD6F4"/>
        <TextBlock Text="{Binding [RAIntegration_Description], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#A6ADC8" TextWrapping="Wrap"/>

        <!-- RetroArch Configuration -->
        <Border Background="#181825" CornerRadius="6" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="{Binding [Settings_RetroArchTitle], Source={x:Static loc:LocalizationManager.Instance}}"
                           FontWeight="SemiBold" Foreground="#CDD6F4"/>
                <TextBlock Text="{Binding [Settings_RetroArchDescription], Source={x:Static loc:LocalizationManager.Instance}}"
                           Foreground="#A6ADC8" FontSize="12" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox x:Name="RetroArchPathTextBox" Width="300" IsReadOnly="True"
                             Watermark="{Binding [Settings_RetroArchPathPlaceholder], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    <Button x:Name="BrowseRetroArchButton" Content="{Binding [Settings_RetroArchBrowse], Source={x:Static loc:LocalizationManager.Instance}}"
                            Click="BrowseRetroArchButton_Click" Padding="12,6"/>
                    <Button x:Name="DetectRetroArchButton" Content="{Binding [Settings_RetroArchDetect], Source={x:Static loc:LocalizationManager.Instance}}"
                            Click="DetectRetroArchButton_Click" Padding="12,6"/>
                </StackPanel>
                <TextBlock x:Name="RetroArchStatusText" Foreground="#A6ADC8" FontSize="11" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="DownloadRetroArchButton" Content="{Binding [Settings_RetroArchDownload], Source={x:Static loc:LocalizationManager.Instance}}"
                            Click="DownloadRetroArchButton_Click" Padding="12,6"/>
                    <Button x:Name="ClearRetroArchButton" Content="{Binding [Settings_RetroArchClear], Source={x:Static loc:LocalizationManager.Instance}}"
                            Click="ClearRetroArchButton_Click" Padding="12,6"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- RetroArch Core Downloader -->
        <Border Background="#181825" CornerRadius="6" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="{Binding [Settings_CoreDownloaderTitle], Source={x:Static loc:LocalizationManager.Instance}}"
                           FontWeight="SemiBold" Foreground="#CDD6F4"/>
                <TextBlock Text="{Binding [Settings_CoreDownloaderDescription], Source={x:Static loc:LocalizationManager.Instance}}"
                           Foreground="#A6ADC8" FontSize="12" TextWrapping="Wrap"/>

                <!-- Action buttons -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="CheckCoresButton" Content="{Binding [Settings_CheckCores], Source={x:Static loc:LocalizationManager.Instance}}"
                            Click="CheckCoresButton_Click" Padding="12,6"/>
                    <Button x:Name="DownloadMissingCoresButton" Content="{Binding [Settings_DownloadMissing], Source={x:Static loc:LocalizationManager.Instance}}"
                            Click="DownloadMissingCoresButton_Click" Padding="12,6"/>
                    <Button x:Name="CancelDownloadButton" Content="{Binding [Settings_CancelDownload], Source={x:Static loc:LocalizationManager.Instance}}"
                            Click="CancelDownloadButton_Click" Padding="12,6" IsVisible="False"/>
                </StackPanel>

                <!-- Progress text -->
                <TextBlock x:Name="CoreDownloadStatusText" Foreground="#A6ADC8" FontSize="11" TextWrapping="Wrap"/>

                <!-- Core list (scrollable) -->
                <Border Background="#11111B" CornerRadius="4" Padding="8" MaxHeight="300">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="CoresList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                                        <TextBlock Text="{Binding StatusIcon}" FontSize="12" VerticalAlignment="Center" MinWidth="20"/>
                                        <TextBlock Text="{Binding CoreName}" Foreground="#CDD6F4" FontSize="12" VerticalAlignment="Center" MinWidth="140" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding DisplayName}" Foreground="#6C7086" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </Border>

        <!-- Controller Profiles -->
        <Border Background="#181825" CornerRadius="6" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="{Binding [Settings_ControllerProfilesTitle], Source={x:Static loc:LocalizationManager.Instance}}"
                           FontWeight="SemiBold" Foreground="#CDD6F4"/>
                <TextBlock Text="{Binding [Settings_ControllerProfilesDescription], Source={x:Static loc:LocalizationManager.Instance}}"
                           Foreground="#A6ADC8" FontSize="12" TextWrapping="Wrap"/>
                <TextBlock x:Name="ControllerProfilesInfoText" Foreground="#6C7086" FontSize="11" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="DownloadControllerProfilesButton"
                            Content="{Binding [Settings_ControllerProfilesDownload], Source={x:Static loc:LocalizationManager.Instance}}"
                            Click="DownloadControllerProfilesButton_Click" Padding="12,6"/>
                    <Button x:Name="OpenGamepadToolButton"
                            Content="{Binding [Settings_GamepadToolOpen], Source={x:Static loc:LocalizationManager.Instance}}"
                            Click="OpenGamepadToolButton_Click" Padding="12,6"/>
                </StackPanel>
                <TextBlock x:Name="ControllerProfilesStatusText" Foreground="#A6ADC8" FontSize="11" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </StackPanel>
    </ScrollViewer>
</UserControl>
