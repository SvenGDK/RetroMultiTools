<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:RetroMultiTools.Localization"
             xmlns:md="clr-namespace:Markdown.Avalonia;assembly=Markdown.Avalonia"
             x:Class="RetroMultiTools.Views.SettingsView">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Left">
        <TextBlock Text="{Binding [Settings_Title], Source={x:Static loc:LocalizationManager.Instance}}"
                   FontSize="18" FontWeight="Bold" Foreground="#CDD6F4"/>
        <TextBlock Text="{Binding [Settings_Description], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#A6ADC8" TextWrapping="Wrap"/>

        <!-- Language Selection -->
        <Border Background="#181825" CornerRadius="6" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="{Binding [Settings_Language], Source={x:Static loc:LocalizationManager.Instance}}"
                           FontWeight="SemiBold" Foreground="#CDD6F4"/>
                <TextBlock Text="{Binding [Settings_LanguageDescription], Source={x:Static loc:LocalizationManager.Instance}}"
                           Foreground="#A6ADC8" FontSize="12" TextWrapping="Wrap"/>
                <ComboBox x:Name="LanguageCombo" MinWidth="350" HorizontalAlignment="Left"
                          SelectionChanged="LanguageCombo_SelectionChanged"/>
                <TextBlock Text="{Binding [Settings_RestartNote], Source={x:Static loc:LocalizationManager.Instance}}"
                           Foreground="#6C7086" FontSize="11" FontStyle="Italic" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Discord Rich Presence -->
        <Border Background="#181825" CornerRadius="6" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="{Binding [Settings_Discord], Source={x:Static loc:LocalizationManager.Instance}}" FontWeight="SemiBold" Foreground="#CDD6F4"/>
                <CheckBox x:Name="DiscordRichPresenceCheck"
                          Content="{Binding [Discord_EnableRichPresence], Source={x:Static loc:LocalizationManager.Instance}}"
                          Foreground="#CDD6F4"
                          IsCheckedChanged="DiscordRichPresenceCheck_Changed"/>
            </StackPanel>
        </Border>

        <!-- System Tray -->
        <Border Background="#181825" CornerRadius="6" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="{Binding [Settings_SystemTray], Source={x:Static loc:LocalizationManager.Instance}}" FontWeight="SemiBold" Foreground="#CDD6F4"/>
                <CheckBox x:Name="MinimizeToTrayOnLaunchCheck"
                          Content="{Binding [Settings_MinimizeToTrayOnLaunch], Source={x:Static loc:LocalizationManager.Instance}}"
                          Foreground="#CDD6F4"
                          IsCheckedChanged="MinimizeToTrayOnLaunchCheck_Changed"/>
            </StackPanel>
        </Border>

        <!-- Big Picture Mode -->
        <Border Background="#181825" CornerRadius="6" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="{Binding [Settings_BigPictureTitle], Source={x:Static loc:LocalizationManager.Instance}}"
                           FontWeight="SemiBold" Foreground="#CDD6F4"/>
                <TextBlock Text="{Binding [Settings_BigPictureDescription], Source={x:Static loc:LocalizationManager.Instance}}"
                           Foreground="#A6ADC8" FontSize="12" TextWrapping="Wrap"/>
                <CheckBox x:Name="StartInBigPictureModeCheck"
                          Content="{Binding [Settings_BigPictureAutoStart], Source={x:Static loc:LocalizationManager.Instance}}"
                          Foreground="#CDD6F4"
                          IsCheckedChanged="StartInBigPictureModeCheck_Changed"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox x:Name="BigPictureRomFolderTextBox" Width="300" IsReadOnly="True"
                             Watermark="{Binding [Settings_BigPictureFolderPlaceholder], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    <Button x:Name="BrowseBigPictureFolderButton"
                            Content="{Binding [Settings_Browse], Source={x:Static loc:LocalizationManager.Instance}}"
                            Click="BrowseBigPictureFolderButton_Click" Padding="12,6"/>
                </StackPanel>
                <TextBlock Text="{Binding [Settings_BigPictureCardScaleLabel], Source={x:Static loc:LocalizationManager.Instance}}"
                           Foreground="#CDD6F4" FontSize="12" Margin="0,4,0,0"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Slider x:Name="BigPictureCardScaleSlider" Minimum="0.5" Maximum="2.0"
                            TickFrequency="0.1" IsSnapToTickEnabled="True" Width="250"
                            ValueChanged="BigPictureCardScaleSlider_ValueChanged"/>
                    <TextBlock x:Name="BigPictureCardScaleValueText" Foreground="#6C7086" FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{Binding [Settings_BigPictureScreensaverLabel], Source={x:Static loc:LocalizationManager.Instance}}"
                           Foreground="#CDD6F4" FontSize="12" Margin="0,4,0,0"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Slider x:Name="BigPictureScreensaverSlider" Minimum="0" Maximum="30"
                            TickFrequency="1" IsSnapToTickEnabled="True" Width="250"
                            ValueChanged="BigPictureScreensaverSlider_ValueChanged"/>
                    <TextBlock x:Name="BigPictureScreensaverValueText" Foreground="#6C7086" FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <CheckBox x:Name="BigPicturePlayTrackingCheck"
                          Content="{Binding [Settings_BigPicturePlayTracking], Source={x:Static loc:LocalizationManager.Instance}}"
                          Foreground="#CDD6F4"
                          IsCheckedChanged="BigPicturePlayTrackingCheck_Changed"/>
                <CheckBox x:Name="BigPictureRatingsCheck"
                          Content="{Binding [Settings_BigPictureRatings], Source={x:Static loc:LocalizationManager.Instance}}"
                          Foreground="#CDD6F4"
                          IsCheckedChanged="BigPictureRatingsCheck_Changed"/>
            </StackPanel>
        </Border>

        <!-- Gamepad -->
        <Border Background="#181825" CornerRadius="6" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="{Binding [Settings_GamepadTitle], Source={x:Static loc:LocalizationManager.Instance}}"
                           FontWeight="SemiBold" Foreground="#CDD6F4"/>
                <TextBlock Text="{Binding [Settings_GamepadDescription], Source={x:Static loc:LocalizationManager.Instance}}"
                           Foreground="#A6ADC8" FontSize="12" TextWrapping="Wrap"/>
                <CheckBox x:Name="GamepadEnabledCheck"
                          Content="{Binding [Settings_GamepadEnabled], Source={x:Static loc:LocalizationManager.Instance}}"
                          Foreground="#CDD6F4"
                          IsCheckedChanged="GamepadEnabledCheck_Changed"/>
                <TextBlock Text="{Binding [Settings_GamepadDeadZoneLabel], Source={x:Static loc:LocalizationManager.Instance}}"
                           Foreground="#CDD6F4" FontSize="12" Margin="0,4,0,0"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Slider x:Name="GamepadDeadZoneSlider" Minimum="0.05" Maximum="0.95"
                            TickFrequency="0.05" IsSnapToTickEnabled="True" Width="250"
                            ValueChanged="GamepadDeadZoneSlider_ValueChanged"/>
                    <TextBlock x:Name="GamepadDeadZoneValueText" Foreground="#6C7086" FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Application Updates -->
        <Border Background="#181825" CornerRadius="6" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="{Binding [Settings_UpdateTitle], Source={x:Static loc:LocalizationManager.Instance}}"
                           FontWeight="SemiBold" Foreground="#CDD6F4"/>
                <TextBlock Text="{Binding [Settings_UpdateDescription], Source={x:Static loc:LocalizationManager.Instance}}"
                           Foreground="#A6ADC8" FontSize="12" TextWrapping="Wrap"/>
                <CheckBox x:Name="CheckForUpdatesOnStartupCheck"
                          Content="{Binding [Settings_UpdateAutoCheck], Source={x:Static loc:LocalizationManager.Instance}}"
                          Foreground="#CDD6F4"
                          IsCheckedChanged="CheckForUpdatesOnStartupCheck_Changed"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="CheckForUpdatesButton"
                            Content="{Binding [Settings_UpdateCheckNow], Source={x:Static loc:LocalizationManager.Instance}}"
                            Click="CheckForUpdatesButton_Click" Padding="12,6"/>
                    <Button x:Name="InstallUpdateButton"
                            Content="{Binding [Settings_UpdateInstallNow], Source={x:Static loc:LocalizationManager.Instance}}"
                            Click="InstallUpdateButton_Click" Padding="12,6" IsVisible="False"/>
                    <Button x:Name="CancelUpdateButton"
                            Content="{Binding [Settings_CancelDownload], Source={x:Static loc:LocalizationManager.Instance}}"
                            Click="CancelUpdateButton_Click" Padding="12,6" IsVisible="False"/>
                </StackPanel>
                <ProgressBar x:Name="UpdateProgressBar" Minimum="0" Maximum="100"
                             IsVisible="False" Height="6" Margin="0,4,0,0"/>
                <TextBlock x:Name="UpdateStatusText" Foreground="#A6ADC8" FontSize="11" TextWrapping="Wrap"/>
                <Border x:Name="ReleaseNotesBorder" Background="#11161B" CornerRadius="4"
                        Padding="8" IsVisible="False" Margin="0,4,0,0" MaxHeight="260">
                    <md:MarkdownScrollViewer x:Name="ReleaseNotesViewer" />
                </Border>
                <TextBlock x:Name="VersionText" Foreground="#6C7086" FontSize="11"/>
            </StackPanel>
        </Border>
    </StackPanel>
    </ScrollViewer>
</UserControl>
