<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:RetroMultiTools.Localization"
             x:Class="RetroMultiTools.Views.Mame.MameSampleAuditorView">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16" MaxWidth="700" HorizontalAlignment="Left">
        <TextBlock Text="{Binding [MameSamples_Title], Source={x:Static loc:LocalizationManager.Instance}}" FontSize="18" FontWeight="Bold" Foreground="#CDD6F4"/>
        <TextBlock Text="{Binding [MameSamples_Description], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#A6ADC8" TextWrapping="Wrap"/>

        <!-- MAME XML Database -->
        <StackPanel Spacing="4">
            <TextBlock Text="{Binding [MameSamples_XmlFile], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="XmlFileTextBox" IsReadOnly="True"
                         Watermark="{Binding [MameSamples_SelectXml], Source={x:Static loc:LocalizationManager.Instance}}" Padding="8,6"/>
                <Button Grid.Column="1" Content="{Binding [Common_Browse], Source={x:Static loc:LocalizationManager.Instance}}" Click="BrowseXml_Click"
                        Margin="8,0,0,0" Padding="12,6"/>
            </Grid>
        </StackPanel>

        <!-- XML Info -->
        <Border x:Name="XmlInfoPanel" Background="#181825" CornerRadius="6" Padding="12"
                IsVisible="False">
            <TextBlock x:Name="XmlInfoText" Foreground="#A6ADC8" FontSize="12"/>
        </Border>

        <!-- Sample Directory -->
        <StackPanel Spacing="4">
            <TextBlock Text="{Binding [MameSamples_SampleDir], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="SampleDirTextBox" IsReadOnly="True"
                         Watermark="{Binding [MameSamples_SelectSampleDir], Source={x:Static loc:LocalizationManager.Instance}}" Padding="8,6"/>
                <Button Grid.Column="1" Content="{Binding [Common_Browse], Source={x:Static loc:LocalizationManager.Instance}}" Click="BrowseSampleDir_Click"
                        Margin="8,0,0,0" Padding="12,6"/>
            </Grid>
        </StackPanel>

        <!-- Options -->
        <StackPanel Spacing="8">
            <CheckBox x:Name="RecursiveCheckBox" Foreground="#A6ADC8"
                      Content="{Binding [MameSamples_Recursive], Source={x:Static loc:LocalizationManager.Instance}}"/>
        </StackPanel>

        <!-- Audit Button -->
        <Button x:Name="AuditButton" Content="{Binding [MameSamples_Audit], Source={x:Static loc:LocalizationManager.Instance}}"
                Click="AuditButton_Click"
                Padding="16,10" HorizontalAlignment="Left"
                IsEnabled="False"/>

        <!-- Progress -->
        <StackPanel x:Name="ProgressPanel" IsVisible="False" Spacing="4">
            <ProgressBar IsIndeterminate="True" Height="4" Foreground="#89B4FA"/>
            <TextBlock x:Name="ProgressText" Foreground="#A6ADC8" FontSize="12"/>
        </StackPanel>

        <!-- Status -->
        <Border x:Name="StatusBorder" Background="#181825" CornerRadius="6" Padding="12"
                IsVisible="False">
            <TextBlock x:Name="StatusText" TextWrapping="Wrap" Foreground="#CDD6F4"/>
        </Border>

        <!-- Results List -->
        <Border x:Name="ResultsBorder" Background="#181825" CornerRadius="6" Padding="12"
                IsVisible="False" MaxHeight="350">
            <ScrollViewer>
                <TextBlock x:Name="ResultsText" Foreground="#A6ADC8" FontSize="12"
                           FontFamily="Consolas,Courier New,monospace" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>
    </StackPanel>
    </ScrollViewer>
</UserControl>
