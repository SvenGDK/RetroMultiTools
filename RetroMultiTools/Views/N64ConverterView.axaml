<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:RetroMultiTools.Localization"
             x:Class="RetroMultiTools.Views.N64ConverterView">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Left">
        <TextBlock Text="{Binding [N64Conv_Title], Source={x:Static loc:LocalizationManager.Instance}}" FontSize="18" FontWeight="Bold" Foreground="#CDD6F4"/>
        <TextBlock Text="{Binding [N64Conv_Description], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#A6ADC8" TextWrapping="Wrap"/>

        <!-- Input File -->
        <StackPanel Spacing="4">
            <TextBlock Text="{Binding [N64Conv_InputFile], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="InputFileTextBox" IsReadOnly="True"
                         Watermark="{Binding [N64Conv_SelectFile], Source={x:Static loc:LocalizationManager.Instance}}" Padding="8,6"/>
                <Button Grid.Column="1" Content="{Binding [Common_Browse], Source={x:Static loc:LocalizationManager.Instance}}" Click="BrowseInput_Click"
                        Margin="8,0,0,0" Padding="12,6"/>
            </Grid>
        </StackPanel>

        <!-- Detected Format -->
        <Border x:Name="DetectedFormatPanel" Background="#181825" CornerRadius="6" Padding="12"
                IsVisible="False">
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding [N64Conv_DetectedFormat], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8" FontSize="12"/>
                <TextBlock x:Name="DetectedFormatText" FontWeight="Bold" Foreground="#CDD6F4"/>
            </StackPanel>
        </Border>

        <!-- Target Format -->
        <StackPanel Spacing="4">
            <TextBlock Text="{Binding [N64Conv_TargetFormat], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <ComboBox x:Name="TargetFormatCombo" MinWidth="300" HorizontalAlignment="Left"
                      SelectedIndex="0" SelectionChanged="TargetFormatCombo_SelectionChanged">
                <ComboBoxItem Content="{Binding [N64Conv_BigEndian], Source={x:Static loc:LocalizationManager.Instance}}" Tag="z64"/>
                <ComboBoxItem Content="{Binding [N64Conv_LittleEndian], Source={x:Static loc:LocalizationManager.Instance}}" Tag="n64"/>
                <ComboBoxItem Content="{Binding [N64Conv_ByteSwapped], Source={x:Static loc:LocalizationManager.Instance}}" Tag="v64"/>
            </ComboBox>
        </StackPanel>

        <!-- Output File -->
        <StackPanel Spacing="4">
            <TextBlock Text="{Binding [Common_OutputFile], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="OutputFileTextBox" Watermark="{Binding [N64Conv_OutputPath], Source={x:Static loc:LocalizationManager.Instance}}" Padding="8,6"/>
                <Button Grid.Column="1" Content="{Binding [Common_Browse], Source={x:Static loc:LocalizationManager.Instance}}" Click="BrowseOutput_Click"
                        Margin="8,0,0,0" Padding="12,6"/>
            </Grid>
        </StackPanel>

        <!-- Convert Button -->
        <Button x:Name="ConvertButton" Content="{Binding [N64Conv_Convert], Source={x:Static loc:LocalizationManager.Instance}}"
                Click="ConvertButton_Click"
                Padding="16,10" HorizontalAlignment="Left"
                IsEnabled="False"/>

        <!-- Progress -->
        <StackPanel x:Name="ProgressPanel" IsVisible="False" Spacing="4">
            <ProgressBar IsIndeterminate="True" Height="4" Foreground="#89B4FA"/>
            <TextBlock x:Name="ProgressText" Foreground="#A6ADC8" FontSize="12"/>
        </StackPanel>

        <!-- Status -->
        <Border x:Name="StatusBorder" Background="#181825" CornerRadius="6" Padding="12"
                IsVisible="False">
            <TextBlock x:Name="StatusText" TextWrapping="Wrap" Foreground="#CDD6F4"/>
        </Border>
    </StackPanel>
    </ScrollViewer>
</UserControl>
