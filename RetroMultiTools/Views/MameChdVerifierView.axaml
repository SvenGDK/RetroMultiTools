<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:RetroMultiTools.Localization"
             x:Class="RetroMultiTools.Views.MameChdVerifierView">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16" MaxWidth="700" HorizontalAlignment="Left">
        <TextBlock Text="{Binding [MameChd_Title], Source={x:Static loc:LocalizationManager.Instance}}" FontSize="18" FontWeight="Bold" Foreground="#CDD6F4"/>
        <TextBlock Text="{Binding [MameChd_Description], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#A6ADC8" TextWrapping="Wrap"/>

        <!-- Mode Selection -->
        <StackPanel Spacing="4">
            <TextBlock Text="{Binding [Common_Mode], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <RadioButton x:Name="SingleModeRadio" Content="{Binding [MameChd_SingleFile], Source={x:Static loc:LocalizationManager.Instance}}"
                             GroupName="ChdVerifierMode"
                             IsChecked="True" Foreground="#CDD6F4"
                             IsCheckedChanged="ModeRadio_Checked"/>
                <RadioButton x:Name="BatchModeRadio" Content="{Binding [Common_BatchDirectory], Source={x:Static loc:LocalizationManager.Instance}}"
                             GroupName="ChdVerifierMode"
                             Foreground="#CDD6F4"
                             IsCheckedChanged="ModeRadio_Checked"/>
            </StackPanel>
        </StackPanel>

        <!-- File/Directory Selection -->
        <StackPanel Spacing="4">
            <TextBlock x:Name="InputLabel" Text="{Binding [MameChd_ChdFile], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="InputTextBox" IsReadOnly="True"
                         Watermark="{Binding [MameChd_SelectChd], Source={x:Static loc:LocalizationManager.Instance}}" Padding="8,6"/>
                <Button Grid.Column="1" Content="{Binding [Common_Browse], Source={x:Static loc:LocalizationManager.Instance}}" Click="BrowseInput_Click"
                        Margin="8,0,0,0" Padding="12,6"/>
            </Grid>
        </StackPanel>

        <!-- Verify Button -->
        <Button x:Name="VerifyButton" Content="{Binding [MameChd_Verify], Source={x:Static loc:LocalizationManager.Instance}}"
                Click="VerifyButton_Click"
                Padding="16,10" HorizontalAlignment="Left"
                IsEnabled="False"/>

        <!-- Progress -->
        <StackPanel x:Name="ProgressPanel" IsVisible="False" Spacing="4">
            <ProgressBar IsIndeterminate="True" Height="4" Foreground="#89B4FA"/>
            <TextBlock x:Name="ProgressText" Foreground="#A6ADC8" FontSize="12"/>
        </StackPanel>

        <!-- Status -->
        <Border x:Name="StatusBorder" Background="#181825" CornerRadius="6" Padding="12"
                IsVisible="False">
            <TextBlock x:Name="StatusText" TextWrapping="Wrap" Foreground="#CDD6F4"/>
        </Border>

        <!-- Results List -->
        <Border x:Name="ResultsBorder" Background="#181825" CornerRadius="6" Padding="12"
                IsVisible="False" MaxHeight="350">
            <ScrollViewer>
                <TextBlock x:Name="ResultsText" Foreground="#A6ADC8" FontSize="12"
                           FontFamily="Consolas,Courier New,monospace" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>
    </StackPanel>
    </ScrollViewer>
</UserControl>
