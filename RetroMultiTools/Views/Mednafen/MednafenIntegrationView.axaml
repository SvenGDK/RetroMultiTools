<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:RetroMultiTools.Localization"
             x:Class="RetroMultiTools.Views.Mednafen.MednafenIntegrationView">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Left">
        <TextBlock Text="{Binding [MednafenIntegration_Title], Source={x:Static loc:LocalizationManager.Instance}}"
                   FontSize="18" FontWeight="Bold" Foreground="#CDD6F4"/>
        <TextBlock Text="{Binding [MednafenIntegration_Description], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#A6ADC8" TextWrapping="Wrap"/>

        <!-- Mednafen Configuration -->
        <Border Background="#181825" CornerRadius="6" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="{Binding [Settings_MednafenTitle], Source={x:Static loc:LocalizationManager.Instance}}"
                           FontWeight="SemiBold" Foreground="#CDD6F4"/>
                <TextBlock Text="{Binding [Settings_MednafenDescription], Source={x:Static loc:LocalizationManager.Instance}}"
                           Foreground="#A6ADC8" FontSize="12" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox x:Name="MednafenPathTextBox" Width="300"
                             Watermark="{Binding [Settings_MednafenPathPlaceholder], Source={x:Static loc:LocalizationManager.Instance}}"
                             KeyDown="MednafenPathTextBox_KeyDown"/>
                    <Button x:Name="BrowseMednafenButton" Content="{Binding [Settings_Browse], Source={x:Static loc:LocalizationManager.Instance}}"
                            Click="BrowseMednafenButton_Click" Padding="12,6"/>
                    <Button x:Name="DetectMednafenButton" Content="{Binding [Settings_AutoDetect], Source={x:Static loc:LocalizationManager.Instance}}"
                            Click="DetectMednafenButton_Click" Padding="12,6"/>
                </StackPanel>
                <TextBlock x:Name="MednafenStatusText" Foreground="#A6ADC8" FontSize="11" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="DownloadMednafenButton" Content="{Binding [Settings_MednafenDownload], Source={x:Static loc:LocalizationManager.Instance}}"
                            Click="DownloadMednafenButton_Click" Padding="12,6"/>
                    <Button x:Name="ClearMednafenButton" Content="{Binding [Settings_Clear], Source={x:Static loc:LocalizationManager.Instance}}"
                            Click="ClearMednafenButton_Click" Padding="12,6"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
    </ScrollViewer>
</UserControl>
