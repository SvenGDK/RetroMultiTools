<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:RetroMultiTools.Localization"
             x:Class="RetroMultiTools.Views.Analogue.AnaloguePocketView">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16" MaxWidth="800" HorizontalAlignment="Left">
        <TextBlock Text="{Binding [AnaloguePocket_Title], Source={x:Static loc:LocalizationManager.Instance}}" FontSize="18" FontWeight="Bold" Foreground="#CDD6F4"/>
        <TextBlock Text="{Binding [AnaloguePocket_Description], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#A6ADC8" TextWrapping="Wrap"/>

        <!-- SD Card Path -->
        <StackPanel Spacing="4">
            <TextBlock Text="{Binding [AnaloguePocket_SdCardPath], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="SdCardPathTextBox" IsReadOnly="True"
                         Watermark="{Binding [AnaloguePocket_SelectSdCard], Source={x:Static loc:LocalizationManager.Instance}}" Padding="8,6"/>
                <Button Grid.Column="1" Content="{Binding [Common_Browse], Source={x:Static loc:LocalizationManager.Instance}}" Click="BrowseSdCard_Click"
                        Margin="8,0,0,0" Padding="12,6"/>
            </Grid>
        </StackPanel>

        <!-- Feature Buttons -->
        <TextBlock Text="{Binding [AnaloguePocket_Features], Source={x:Static loc:LocalizationManager.Instance}}"
                   FontSize="14" FontWeight="SemiBold" Foreground="#CDD6F4" Margin="0,8,0,0"/>

        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
            <Button x:Name="BrowseCoresButton" Content="{Binding [AnaloguePocket_BrowseCores], Source={x:Static loc:LocalizationManager.Instance}}"
                    Click="BrowseCores_Click" Padding="14,10" Margin="0,0,8,8" IsEnabled="False"/>
            <Button x:Name="ExportScreenshotsButton" Content="{Binding [AnaloguePocket_ExportScreenshots], Source={x:Static loc:LocalizationManager.Instance}}"
                    Click="ExportScreenshots_Click" Padding="14,10" Margin="0,0,8,8" IsEnabled="False"/>
            <Button x:Name="BackupSavesButton" Content="{Binding [AnaloguePocket_BackupSaves], Source={x:Static loc:LocalizationManager.Instance}}"
                    Click="BackupSaves_Click" Padding="14,10" Margin="0,0,8,8" IsEnabled="False"/>
            <Button x:Name="RestoreSavesButton" Content="{Binding [AnaloguePocket_RestoreSaves], Source={x:Static loc:LocalizationManager.Instance}}"
                    Click="RestoreSaves_Click" Padding="14,10" Margin="0,0,8,8" IsEnabled="False"/>
            <Button x:Name="OpenGameFoldersButton" Content="{Binding [AnaloguePocket_OpenGameFolders], Source={x:Static loc:LocalizationManager.Instance}}"
                    Click="OpenGameFolders_Click" Padding="14,10" Margin="0,0,8,8" IsEnabled="False"/>
            <Button x:Name="ManageSaveStatesButton" Content="{Binding [AnaloguePocket_ManageSaveStates], Source={x:Static loc:LocalizationManager.Instance}}"
                    Click="ManageSaveStates_Click" Padding="14,10" Margin="0,0,8,8" IsEnabled="False"/>
            <Button x:Name="ExportGbCameraButton" Content="{Binding [AnaloguePocket_ExportGbCamera], Source={x:Static loc:LocalizationManager.Instance}}"
                    Click="ExportGbCamera_Click" Padding="14,10" Margin="0,0,8,8" IsEnabled="False"/>
            <Button x:Name="AutoCopyFilesButton" Content="{Binding [AnaloguePocket_AutoCopyFiles], Source={x:Static loc:LocalizationManager.Instance}}"
                    Click="AutoCopyFiles_Click" Padding="14,10" Margin="0,0,8,8" IsEnabled="False"/>
            <Button x:Name="LibraryImageGenButton" Content="{Binding [AnaloguePocket_LibraryImageGen], Source={x:Static loc:LocalizationManager.Instance}}"
                    Click="LibraryImageGen_Click" Padding="14,10" Margin="0,0,8,8" IsEnabled="False"/>
        </WrapPanel>

        <!-- Progress -->
        <StackPanel x:Name="ProgressPanel" IsVisible="False" Spacing="4">
            <ProgressBar IsIndeterminate="True" Height="4" Foreground="#89B4FA"/>
            <TextBlock x:Name="ProgressText" Foreground="#A6ADC8" FontSize="12"/>
        </StackPanel>

        <!-- Status -->
        <Border x:Name="StatusBorder" Background="#181825" CornerRadius="6" Padding="12"
                IsVisible="False">
            <TextBlock x:Name="StatusText" TextWrapping="Wrap" Foreground="#CDD6F4"/>
        </Border>

        <!-- Results Panel (for cores, save states, game folders) -->
        <Border x:Name="ResultsBorder" Background="#181825" CornerRadius="6" Padding="12"
                IsVisible="False" MaxHeight="400">
            <ScrollViewer>
                <StackPanel x:Name="ResultsPanel" Spacing="4"/>
            </ScrollViewer>
        </Border>
    </StackPanel>
    </ScrollViewer>
</UserControl>
