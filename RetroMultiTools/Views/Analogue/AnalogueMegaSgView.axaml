<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:RetroMultiTools.Localization"
             x:Class="RetroMultiTools.Views.Analogue.AnalogueMegaSgView">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16" MaxWidth="700" HorizontalAlignment="Left">
        <TextBlock Text="{Binding [AnalogueMegaSg_Title], Source={x:Static loc:LocalizationManager.Instance}}" FontSize="18" FontWeight="Bold" Foreground="#CDD6F4"/>
        <TextBlock Text="{Binding [AnalogueMegaSg_Description], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#A6ADC8" TextWrapping="Wrap"/>

        <!-- SD Card Path -->
        <StackPanel Spacing="4">
            <TextBlock Text="{Binding [AnalogueMegaSg_SdCardPath], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="SdCardPathTextBox" IsReadOnly="True"
                         Watermark="{Binding [AnalogueMegaSg_SelectSdCard], Source={x:Static loc:LocalizationManager.Instance}}" Padding="8,6"/>
                <Button Grid.Column="1" Content="{Binding [Common_Browse], Source={x:Static loc:LocalizationManager.Instance}}" Click="BrowseSdCard_Click"
                        Margin="8,0,0,0" Padding="12,6"/>
            </Grid>
        </StackPanel>

        <!-- Font Generator Section -->
        <TextBlock Text="{Binding [AnalogueMegaSg_FontGenerator], Source={x:Static loc:LocalizationManager.Instance}}"
                   FontSize="14" FontWeight="SemiBold" Foreground="#CDD6F4" Margin="0,8,0,0"/>
        <TextBlock Text="{Binding [AnalogueMegaSg_FontDescription], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#A6ADC8" TextWrapping="Wrap" FontSize="12"/>

        <StackPanel Spacing="4">
            <TextBlock Text="{Binding [Analogue_FontSourceImage], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="FontImageTextBox" IsReadOnly="True"
                         Watermark="{Binding [Analogue_FontSourceWatermark], Source={x:Static loc:LocalizationManager.Instance}}" Padding="8,6"/>
                <Button Grid.Column="1" Content="{Binding [Common_Browse], Source={x:Static loc:LocalizationManager.Instance}}" Click="BrowseFontImage_Click"
                        Margin="8,0,0,0" Padding="12,6"/>
            </Grid>
        </StackPanel>

        <Button x:Name="GenerateFontButton" Content="{Binding [Analogue_GenerateFont], Source={x:Static loc:LocalizationManager.Instance}}"
                Click="GenerateFont_Click" Padding="14,10" IsEnabled="False"/>

        <!-- Saves-Manager Section -->
        <TextBlock Text="{Binding [AnalogueMegaSg_SavesManager], Source={x:Static loc:LocalizationManager.Instance}}"
                   FontSize="14" FontWeight="SemiBold" Foreground="#CDD6F4" Margin="0,12,0,0"/>
        <TextBlock Text="{Binding [AnalogueMegaSg_SavesDescription], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#A6ADC8" TextWrapping="Wrap" FontSize="12"/>

        <StackPanel Spacing="4">
            <TextBlock Text="{Binding [AnalogueMegaSg_SaveFile], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="SaveFileTextBox" IsReadOnly="True"
                         Watermark="{Binding [AnalogueMegaSg_SelectSaveFile], Source={x:Static loc:LocalizationManager.Instance}}" Padding="8,6"/>
                <Button Grid.Column="1" Content="{Binding [Common_Browse], Source={x:Static loc:LocalizationManager.Instance}}" Click="BrowseSaveFile_Click"
                        Margin="8,0,0,0" Padding="12,6"/>
            </Grid>
        </StackPanel>

        <!-- Save File Info -->
        <Border x:Name="SaveInfoPanel" Background="#181825" CornerRadius="6" Padding="12"
                IsVisible="False">
            <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding [AnalogueMegaSg_FileSize], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8" Margin="0,0,12,6"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="SaveFileSizeText" Foreground="#CDD6F4" Margin="0,0,0,6"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding [AnalogueMegaSg_DetectedType], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8" Margin="0,0,12,6"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SaveDetectedTypeText" Foreground="#CDD6F4" Margin="0,0,0,6"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding [AnalogueMegaSg_PowerOfTwo], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8" Margin="0,0,12,0"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="SavePowerOfTwoText" Foreground="#CDD6F4"/>
            </Grid>
        </Border>

        <StackPanel Spacing="4">
            <TextBlock Text="{Binding [AnalogueMegaSg_Conversion], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#A6ADC8"/>
            <ComboBox x:Name="ConversionComboBox" Width="300" SelectedIndex="0">
                <ComboBoxItem Content="Swap Endian (16-bit)"/>
                <ComboBoxItem Content="Swap Endian (32-bit)"/>
                <ComboBoxItem Content="Pad to Power of Two"/>
                <ComboBoxItem Content="Trim Trailing Zeros"/>
                <ComboBoxItem Content="Trim Trailing 0xFF"/>
                <ComboBoxItem Content="SRM → SAV"/>
                <ComboBoxItem Content="SAV → SRM"/>
            </ComboBox>
        </StackPanel>

        <Button x:Name="ConvertSaveButton" Content="{Binding [AnalogueMegaSg_ConvertSave], Source={x:Static loc:LocalizationManager.Instance}}"
                Click="ConvertSave_Click" Padding="14,10" IsEnabled="False"/>

        <!-- Progress -->
        <StackPanel x:Name="ProgressPanel" IsVisible="False" Spacing="4">
            <ProgressBar IsIndeterminate="True" Height="4" Foreground="#89B4FA"/>
            <TextBlock x:Name="ProgressText" Foreground="#A6ADC8" FontSize="12"/>
        </StackPanel>

        <!-- Status -->
        <Border x:Name="StatusBorder" Background="#181825" CornerRadius="6" Padding="12"
                IsVisible="False">
            <TextBlock x:Name="StatusText" TextWrapping="Wrap" Foreground="#CDD6F4"/>
        </Border>
    </StackPanel>
    </ScrollViewer>
</UserControl>
