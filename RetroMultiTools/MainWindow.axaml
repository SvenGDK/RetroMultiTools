<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:RetroMultiTools.Localization"
        x:Class="RetroMultiTools.MainWindow"
                Icon="avares://RetroMultiTools/Assets/Icon.png"
        Width="1600" Height="850"
        MinWidth="1280" MinHeight="720"
        WindowStartupLocation="CenterScreen">

    <DockPanel>
        <!-- Top Title Bar -->
        <Border x:Name="TitleBar" DockPanel.Dock="Top" Background="#1E1E2E" Padding="16,10">
            <TextBlock Text="{Binding [AppTitle], Source={x:Static loc:LocalizationManager.Instance}}"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#CDD6F4" VerticalAlignment="Center"/>
        </Border>

        <!-- Left Sidebar -->
        <Border x:Name="Sidebar" DockPanel.Dock="Left" Background="#181825" Width="210" Padding="8">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <ListBox x:Name="NavListBox"
                     Background="Transparent"
                     SelectionChanged="NavListBox_SelectionChanged">
                <!-- Browse & Inspect -->
                <ListBoxItem IsEnabled="False" IsHitTestVisible="False" Focusable="False" Padding="0">
                    <TextBlock Text="{Binding [Nav_BrowseInspect], Source={x:Static loc:LocalizationManager.Instance}}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="#6C7086" Margin="10,6,0,2"/>
                </ListBoxItem>
                <ListBoxItem Tag="browser" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M1 3h6l2 2h10v12H1V3zm2 2v10h14V7H8.17L6.17 5H3z"/>
                        <TextBlock Text="{Binding [Nav_RomBrowser], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="inspector" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M10 2a8 8 0 105.29 14.29l3.71 3.71 1.41-1.41-3.71-3.71A8 8 0 0010 2zm0 2a6 6 0 110 12 6 6 0 010-12z"/>
                        <TextBlock Text="{Binding [Nav_RomInspector], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="hexviewer" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"/>
                        <TextBlock Text="{Binding [Nav_HexViewer], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>

                <!-- Patching & Conversion -->
                <ListBoxItem IsEnabled="False" IsHitTestVisible="False" Focusable="False" Padding="0">
                    <TextBlock Text="{Binding [Nav_PatchingConversion], Source={x:Static loc:LocalizationManager.Instance}}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="#6C7086" Margin="10,10,0,2"/>
                </ListBoxItem>
                <ListBoxItem Tag="formatconv" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm-1 7V3.5L18.5 9H13z"/>
                        <TextBlock Text="{Binding [Nav_FormatConvert], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="n64conv" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M6.99 11L3 15l3.99 4v-3H14v-2H6.99V11zM21 9l-3.99-4v3H10v2h7.01v3L21 9z"/>
                        <TextBlock Text="{Binding [Nav_N64Converter], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="patchcreator" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04a1 1 0 000-1.41l-2.34-2.34a1 1 0 00-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
                        <TextBlock Text="{Binding [Nav_PatchCreator], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="patcher" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M19.36 2.72l1.42 1.42-5.72 5.71c1.07 1.54 1.22 3.39.32 4.59L9.06 8.12c1.2-.9 3.05-.75 4.59.32l5.71-5.72zM5.93 17.57c-2.01-2.01-3.24-4.41-3.58-6.65l4.88-2.09 7.44 7.44-2.09 4.88c-2.24-.34-4.64-1.57-6.65-3.58z"/>
                        <TextBlock Text="{Binding [Nav_RomPatcher], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="saveconv" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M17 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z"/>
                        <TextBlock Text="{Binding [Nav_SaveConverter], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="splitrom" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M11 17h2v-1h1c.55 0 1-.45 1-1v-3c0-.55-.45-1-1-1h-3v-1h4V8h-2V7h-2v1h-1c-.55 0-1 .45-1 1v3c0 .55.45 1 1 1h3v1H9v2h2v1z"/>
                        <TextBlock Text="{Binding [Nav_SplitAssembler], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>

                <!-- Analysis & Verification -->
                <ListBoxItem IsEnabled="False" IsHitTestVisible="False" Focusable="False" Padding="0">
                    <TextBlock Text="{Binding [Nav_AnalysisVerification], Source={x:Static loc:LocalizationManager.Instance}}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="#6C7086" Margin="10,10,0,2"/>
                </ListBoxItem>
                <ListBoxItem Tag="batchhash" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M18 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM6 4h5v8l-2.5-1.5L6 12V4z"/>
                        <TextBlock Text="{Binding [Nav_BatchHasher], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="checksum" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/>
                        <TextBlock Text="{Binding [Nav_ChecksumCalc], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="datfilter" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M10 18h4v-2h-4v2zM3 6v2h18V6H3zm3 7h12v-2H6v2z"/>
                        <TextBlock Text="{Binding [Nav_DatFilter], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="datverifier" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                        <TextBlock Text="{Binding [Nav_DatVerifier], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="dumpverifier" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/>
                        <TextBlock Text="{Binding [Nav_DumpVerifier], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="duplicates" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"/>
                        <TextBlock Text="{Binding [Nav_DuplicateFinder], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="goodtools" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
                        <TextBlock Text="{Binding [Nav_GoodToolsIdentifier], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="comparer" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M10 3H4c-1.1 0-2 .9-2 2v4c0 1.1.9 2 2 2h6c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 10H4c-1.1 0-2 .9-2 2v4c0 1.1.9 2 2 2h6c1.1 0 2-.9 2-2v-4c0-1.1-.9-2-2-2zm10-10h-6c-1.1 0-2 .9-2 2v4c0 1.1.9 2 2 2h6c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 10h-6c-1.1 0-2 .9-2 2v4c0 1.1.9 2 2 2h6c1.1 0 2-.9 2-2v-4c0-1.1-.9-2-2-2z"/>
                        <TextBlock Text="{Binding [Nav_RomComparer], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="security" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zM9 8V6c0-1.66 1.34-3 3-3s3 1.34 3 3v2H9z"/>
                        <TextBlock Text="{Binding [Nav_SecurityAnalysis], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>

                <!-- Headers & Trimming -->
                <ListBoxItem IsEnabled="False" IsHitTestVisible="False" Focusable="False" Padding="0">
                    <TextBlock Text="{Binding [Nav_HeadersTrimming], Source={x:Static loc:LocalizationManager.Instance}}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="#6C7086" Margin="10,10,0,2"/>
                </ListBoxItem>
                <ListBoxItem Tag="export" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/>
                        <TextBlock Text="{Binding [Nav_HeaderExport], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="headerfixer" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z"/>
                        <TextBlock Text="{Binding [Nav_HeaderFixer], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="trimmer" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M9.64 7.64c.23-.5.36-1.05.36-1.64 0-2.21-1.79-4-4-4S2 3.79 2 6s1.79 4 4 4c.59 0 1.14-.13 1.64-.36L10 12l-2.36 2.36C7.14 14.13 6.59 14 6 14c-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4c0-.59-.13-1.14-.36-1.64L12 14l7 7h3v-1L9.64 7.64z"/>
                        <TextBlock Text="{Binding [Nav_RomTrimmer], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="snesheader" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/>
                        <TextBlock Text="{Binding [Nav_SnesHeader], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>

                <!-- Utilities -->
                <ListBoxItem IsEnabled="False" IsHitTestVisible="False" Focusable="False" Padding="0">
                    <TextBlock Text="{Binding [Nav_Utilities], Source={x:Static loc:LocalizationManager.Instance}}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="#6C7086" Margin="10,10,0,2"/>
                </ListBoxItem>
                <ListBoxItem Tag="archives" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M20 6h-8l-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-6 10h-2v2h-1v-2H9v-1h2v-2h1v2h2v1z"/>
                        <TextBlock Text="{Binding [Nav_Archives], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="cheatcodes" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"/>
                        <TextBlock Text="{Binding [Nav_CheatCodes], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="emuconfig" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M21 6H3c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-10 7H8v3H6v-3H3v-2h3V8h2v3h3v2zm4.5 2c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm4-3c-.83 0-1.5-.67-1.5-1.5S18.67 9 19.5 9s1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/>
                        <TextBlock Text="{Binding [Nav_EmulatorConfig], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="gamepadkeymapper" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M17 4H7c-1.66 0-3 1.34-3 3v10c0 1.66 1.34 3 3 3h10c1.66 0 3-1.34 3-3V7c0-1.66-1.34-3-3-3zM10 9a1.5 1.5 0 110-3 1.5 1.5 0 010 3zm0 4a1.5 1.5 0 110-3 1.5 1.5 0 010 3zm4 0a1.5 1.5 0 110-3 1.5 1.5 0 010 3zm0-4a1.5 1.5 0 110-3 1.5 1.5 0 010 3z"/>
                        <TextBlock Text="{Binding [Nav_GamepadKeyMapper], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="metascraper" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zM8 11H4V6h4v5zm6 0h-4V6h4v5zm6 0h-4V6h4v5z"/>
                        <TextBlock Text="{Binding [Nav_MetadataScraper], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="romorganizer" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M20 6h-8l-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-6 10H6v-2h8v2zm4-4H6v-2h12v2z"/>
                        <TextBlock Text="{Binding [Nav_RomOrganizer], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="romrenamer" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M18.41 5.8L17.2 4.59c-.78-.78-2.05-.78-2.83 0l-2.68 2.68L3 15.96V20h4.04l8.74-8.74 2.63-2.63c.79-.78.79-2.05 0-2.83zM6.21 18H5v-1.21l8.66-8.66 1.21 1.21L6.21 18z"/>
                        <TextBlock Text="{Binding [Nav_RomRenamer], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>

                <!-- RetroArch -->
                <ListBoxItem IsEnabled="False" IsHitTestVisible="False" Focusable="False" Padding="0">
                    <TextBlock Text="{Binding [Nav_RetroArch], Source={x:Static loc:LocalizationManager.Instance}}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="#6C7086" Margin="10,10,0,2"/>
                </ListBoxItem>
                <ListBoxItem Tag="raachievements" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                        <TextBlock Text="{Binding [Nav_RetroAchievementsWriter], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="raplaylist" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M14 10H2v2h12v-2zm0-4H2v2h12V6zm4 8v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zM2 16h8v-2H2v2z"/>
                        <TextBlock Text="{Binding [Nav_RetroArchPlaylist], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="raintegration" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
                                  Data="M21 3H3c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H3V5h18v14zM5 15h2V9H5v6zm4 0h2V9H9v6zm4 0h2V9h-2v6zm4 0h2V9h-2v6z"/>
                        <TextBlock Text="{Binding [Nav_RetroArchIntegration], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="rashortcut" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" Foreground="#CDD6F4"
